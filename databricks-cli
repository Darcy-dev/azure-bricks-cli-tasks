  $SrcRg = "source-rg"
  $SrcAa = "source-automation-account"
  $DstRg = "dest-rg"
  $DstAa = "dest-automation-account"

  $vars = az automation variable list `
      --resource-group $SrcRg `
      --automation-account-name $SrcAa `
      -o json | ConvertFrom-Json

  foreach ($v in $vars) {
      if ($v.isEncrypted -or -not $v.value) {
          Write-Host "SKIP (encrypted or unreadable): $($v.name)" -ForegroundColor Yellow
          continue
      }

      Write-Host "Copying: $($v.name)" -ForegroundColor Cyan

      # az expects JSON-encoded values; wrap strings in quotes
      $jsonValue = $v.value | ConvertTo-Json -Compress

      az automation variable create `
          --resource-group $DstRg `
          --automation-account-name $DstAa `
          --name $v.name `
          --value $jsonValue `
          --description ($v.description ?? "") `
          --is-encrypted false `
          -o none
  }

  Alternative using the Az PowerShell module (cleaner, and can read encrypted values' metadata but still not plaintext):

  Import-Module Az.Automation

  $SrcRg = "source-rg"; $SrcAa = "source-automation-account"
  $DstRg = "dest-rg";   $DstAa = "dest-automation-account"

  Get-AzAutomationVariable -ResourceGroupName $SrcRg -AutomationAccountName $SrcAa | ForEach-Object {
      if ($_.Encrypted) {
          Write-Warning "SKIP (encrypted): $($_.Name)"
          return
      }
      Write-Host "Copying: $($_.Name)"
      New-AzAutomationVariable `
          -ResourceGroupName $DstRg `
          -AutomationAccountName $DstAa `
          -Name $_.Name `
          -Value $_.Value `
          -Encrypted $false `
          -Description $_.Description | Out-Null
  }
