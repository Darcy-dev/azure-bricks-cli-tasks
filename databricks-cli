  param(
      [Parameter(Mandatory)] [string] $RunbookName,
      [Parameter(Mandatory)] [string] $ScheduleName,
      [hashtable] $Parameters,
      [string]    $HybridWorkerGroup
  )

  $ErrorActionPreference = "Stop"

  $SubId = "f3bee883-599d-42ef-aeb7-d5fe4abeb4ea"
  $Rg    = "s00175rg-automation"
  $Aa    = "s00175prod"

  Import-Module Az.Automation -ErrorAction Stop
  if (-not (Get-AzContext)) { Connect-AzAccount | Out-Null }
  Set-AzContext -Subscription $SubId | Out-Null

  $splat = @{
      ResourceGroupName     = $Rg
      AutomationAccountName = $Aa
      RunbookName           = $RunbookName
      ScheduleName          = $ScheduleName
  }
  if ($Parameters)        { $splat.Parameters = $Parameters }
  if ($HybridWorkerGroup) { $splat.RunOn      = $HybridWorkerGroup }

  $link = Register-AzAutomationScheduledRunbook @splat
  Write-Host "Linked: $RunbookName -> $ScheduleName" -ForegroundColor Green
