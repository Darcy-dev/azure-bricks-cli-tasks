<#
.SYNOPSIS
    Copy all runbooks from one Azure Automation Account to another.

.DESCRIPTION
    Acquires an ARM token via 'az account get-access-token' and uses native PowerShell
    Invoke-RestMethod to talk to Azure Management API directly. Avoids all the
    'az rest' / 'az automation' command-name and URL-mangling issues on Windows.

.PARAMETER Overwrite
    If specified, existing runbooks in the destination will be deleted and recreated.

.EXAMPLE
    .\Copy-Runbooks-IRM.ps1
    .\Copy-Runbooks-IRM.ps1 -Overwrite

.NOTES
    Requires only:
      - Azure CLI installed and logged in (az login)
      - Subscription context set (az account set --subscription "<id>")
#>

[CmdletBinding()]
param(
    [switch]$Overwrite
)

# ---- Configuration -----------------------------------------------------------
$ResourceGroupName    = 's00175rg-automation'
$SourceAutomationName = 's00175prod-aa'
$DestAutomationName   = 's00175prod'
$ApiVersion           = '2022-08-08'
$ExportPath           = Join-Path $PSScriptRoot 'runbook-export'
# ------------------------------------------------------------------------------

$ErrorActionPreference = 'Stop'
$env:AZURE_CORE_ONLY_SHOW_ERRORS = 'true'

# ---- Acquire ARM token + subscription via az --------------------------------

try {
    $tokenJson = & az account get-access-token --resource 'https://management.azure.com/' --output json 2>$null
    if ($LASTEXITCODE -ne 0) { throw 'Token acquisition failed.' }
    $token = ($tokenJson | ConvertFrom-Json).accessToken
}
catch {
    Write-Error "Failed to get ARM token. Run 'az login' first."
    exit 1
}

try {
    $accountJson    = & az account show --output json 2>$null
    $account        = $accountJson | ConvertFrom-Json
    $subscriptionId = $account.id
    Write-Host "Logged in as: $($account.user.name)" -ForegroundColor Cyan
    Write-Host "Subscription: $($account.name) ($subscriptionId)" -ForegroundColor Cyan
}
catch {
    Write-Error "Failed to read az account context."
    exit 1
}

$Headers = @{ Authorization = "Bearer $token" }
$BaseArm = 'https://management.azure.com'

# ---- Helpers -----------------------------------------------------------------

function Get-RunbookBaseUrl {
    param(
        [string]$AutomationAccount,
        [string]$RunbookName,
        [string]$SubResource = ''
    )
    return "$BaseArm/subscriptions/$subscriptionId/resourceGroups/$ResourceGroupName/providers/Microsoft.Automation/automationAccounts/$AutomationAccount/runbooks/$RunbookName$SubResource" + "?api-version=$ApiVersion"
}

function Invoke-Arm {
    param(
        [string]$Method,
        [string]$Url,
        [object]$Body = $null,
        [string]$ContentType = 'application/json',
        [switch]$Raw     # return response body as raw string (for runbook content)
    )
    $params = @{
        Method  = $Method
        Uri     = $Url
        Headers = $Headers
    }
    if ($Body) {
        $params.Body        = $Body
        $params.ContentType = $ContentType
    }
    if ($Raw) {
        # Use Invoke-WebRequest to get raw content
        $resp = Invoke-WebRequest @params -UseBasicParsing
        return $resp.Content
    }
    return Invoke-RestMethod @params
}

function Get-FileExtensionForRunbook {
    param([string]$RunbookType)
    switch ($RunbookType) {
        'PowerShell'              { 'ps1' }
        'PowerShell72'            { 'ps1' }
        'PowerShellWorkflow'      { 'ps1' }
        'Python2'                 { 'py' }
        'Python3'                 { 'py' }
        'GraphPowerShell'         { 'graphrunbook' }
        'GraphPowerShellWorkflow' { 'graphrunbook' }
        default                   { 'txt' }
    }
}

function Get-ContentTypeForRunbook {
    param([string]$RunbookType)
    switch ($RunbookType) {
        'PowerShell'              { 'text/powershell' }
        'PowerShell72'            { 'text/powershell' }
        'PowerShellWorkflow'      { 'text/powershell' }
        'Python2'                 { 'text/python' }
        'Python3'                 { 'text/python' }
        'GraphPowerShell'         { 'application/json' }
        'GraphPowerShellWorkflow' { 'application/json' }
        default                   { 'text/plain' }
    }
}

# ---- Validate AAs ------------------------------------------------------------

Write-Host "`nValidating Automation Accounts..." -ForegroundColor Cyan

$srcAaUrl  = "$BaseArm/subscriptions/$subscriptionId/resourceGroups/$ResourceGroupName/providers/Microsoft.Automation/automationAccounts/$SourceAutomationName" + "?api-version=$ApiVersion"
$destAaUrl = "$BaseArm/subscriptions/$subscriptionId/resourceGroups/$ResourceGroupName/providers/Microsoft.Automation/automationAccounts/$DestAutomationName" + "?api-version=$ApiVersion"

try {
    $srcAA  = Invoke-Arm -Method GET -Url $srcAaUrl
    $destAA = Invoke-Arm -Method GET -Url $destAaUrl
    Write-Host "  [OK] Source:      $($srcAA.name) ($($srcAA.location))"
    Write-Host "  [OK] Destination: $($destAA.name) ($($destAA.location))"
    $destLocation = $destAA.location
}
catch {
    Write-Error "Failed to access Automation Accounts: $_"
    exit 1
}

# ---- Prep export dir ---------------------------------------------------------

if (Test-Path $ExportPath) { Remove-Item $ExportPath -Recurse -Force }
New-Item -ItemType Directory -Path $ExportPath -Force | Out-Null

# ---- List runbooks -----------------------------------------------------------

Write-Host "`nFetching runbooks from '$SourceAutomationName'..." -ForegroundColor Cyan

$listSrcUrl  = "$BaseArm/subscriptions/$subscriptionId/resourceGroups/$ResourceGroupName/providers/Microsoft.Automation/automationAccounts/$SourceAutomationName/runbooks" + "?api-version=$ApiVersion"
$listDestUrl = "$BaseArm/subscriptions/$subscriptionId/resourceGroups/$ResourceGroupName/providers/Microsoft.Automation/automationAccounts/$DestAutomationName/runbooks" + "?api-version=$ApiVersion"

$srcList  = Invoke-Arm -Method GET -Url $listSrcUrl
$destList = Invoke-Arm -Method GET -Url $listDestUrl

$runbooks = $srcList.value
if (-not $runbooks -or $runbooks.Count -eq 0) {
    Write-Warning 'No runbooks found in source. Nothing to copy.'
    exit 0
}
Write-Host "Found $($runbooks.Count) runbook(s).`n" -ForegroundColor Cyan

$destNames = @($destList.value | Select-Object -ExpandProperty name)

# ---- Copy loop ---------------------------------------------------------------

$results = [System.Collections.Generic.List[pscustomobject]]::new()

foreach ($rb in $runbooks) {
    $name        = $rb.name
    $type        = $rb.properties.runbookType
    $description = if ($rb.properties.description) { $rb.properties.description } else { '' }
    $logVerbose  = [bool]$rb.properties.logVerbose
    $logProgress = [bool]$rb.properties.logProgress

    Write-Host "[$name] type=$type" -ForegroundColor Yellow

    if ($destNames -contains $name -and -not $Overwrite) {
        Write-Host '  -> SKIP (already exists; use -Overwrite to replace)' -ForegroundColor DarkYellow
        $results.Add([pscustomobject]@{ Name = $name; Type = $type; Status = 'Skipped' })
        continue
    }

    $extension   = Get-FileExtensionForRunbook -RunbookType $type
    $contentType = Get-ContentTypeForRunbook   -RunbookType $type
    $contentFile = Join-Path $ExportPath "$name.$extension"

    try {
        # 1. Download published content from source
        Write-Host '  -> Downloading content from source...'
        $contentUrl = Get-RunbookBaseUrl -AutomationAccount $SourceAutomationName -RunbookName $name -SubResource '/content'
        $content = Invoke-Arm -Method GET -Url $contentUrl -Raw
        if (-not $content) { throw "Empty content returned." }
        [System.IO.File]::WriteAllText($contentFile, $content, [System.Text.Encoding]::UTF8)

        # 2. Delete existing destination runbook if overwriting
        if ($destNames -contains $name -and $Overwrite) {
            Write-Host '  -> Deleting existing destination runbook...'
            $deleteUrl = Get-RunbookBaseUrl -AutomationAccount $DestAutomationName -RunbookName $name
            Invoke-Arm -Method DELETE -Url $deleteUrl | Out-Null
        }

        # 3. Create the runbook resource in destination
        Write-Host '  -> Creating runbook in destination...'
        $createUrl = Get-RunbookBaseUrl -AutomationAccount $DestAutomationName -RunbookName $name

        $createBody = @{
            location   = $destLocation
            properties = @{
                runbookType = $type
                description = $description
                logVerbose  = $logVerbose
                logProgress = $logProgress
                draft       = @{}
            }
        } | ConvertTo-Json -Depth 5 -Compress

        Invoke-Arm -Method PUT -Url $createUrl -Body $createBody -ContentType 'application/json' | Out-Null

        # 4. Upload draft content
        Write-Host '  -> Uploading content...'
        $draftContentUrl = Get-RunbookBaseUrl -AutomationAccount $DestAutomationName -RunbookName $name -SubResource '/draft/content'
        $rawContent = [System.IO.File]::ReadAllText($contentFile, [System.Text.Encoding]::UTF8)
        Invoke-Arm -Method PUT -Url $draftContentUrl -Body $rawContent -ContentType $contentType | Out-Null

        # 5. Publish draft
        Write-Host '  -> Publishing...'
        $publishUrl = Get-RunbookBaseUrl -AutomationAccount $DestAutomationName -RunbookName $name -SubResource '/publish'
        Invoke-Arm -Method POST -Url $publishUrl | Out-Null

        Write-Host '  -> DONE' -ForegroundColor Green
        $results.Add([pscustomobject]@{ Name = $name; Type = $type; Status = 'Copied' })
    }
    catch {
        $errMsg = $_.Exception.Message
        # Try to extract Azure error detail
        if ($_.ErrorDetails -and $_.ErrorDetails.Message) {
            $errMsg = $_.ErrorDetails.Message
        }
        Write-Host "  -> FAILED: $errMsg" -ForegroundColor Red
        $results.Add([pscustomobject]@{ Name = $name; Type = $type; Status = "Failed: $errMsg" })
    }
}

# ---- Summary -----------------------------------------------------------------

Write-Host "`n=== Summary ===" -ForegroundColor Cyan
$results | Format-Table -AutoSize

$copied  = ($results | Where-Object Status -eq 'Copied').Count
$skipped = ($results | Where-Object Status -eq 'Skipped').Count
$failed  = ($results | Where-Object { $_.Status -like 'Failed*' }).Count

Write-Host "Copied:  $copied"  -ForegroundColor Green
Write-Host "Skipped: $skipped" -ForegroundColor DarkYellow
Write-Host "Failed:  $failed"  -ForegroundColor $(if ($failed) { 'Red' } else { 'Gray' })
Write-Host "`nExported runbook files preserved in: $ExportPath"

if ($failed -gt 0) { exit 1 }
