  $PSNativeCommandArgumentPassing = 'Legacy'   # PS 7.3+; harmless elsewhere

  $SrcRg = "s00175rgsfd02-1"
  $SrcAa = "s00175autovm"
  $DstRg = "s00175rg-automation"
  $DstAa = "s00175prod"

  Write-Host "Fetching variables from $SrcAa..." -ForegroundColor Cyan
  $vars = az automation variable list `
      --resource-group $SrcRg `
      --automation-account-name $SrcAa `
      -o json | ConvertFrom-Json

  Write-Host "Found $($vars.Count) variables." -ForegroundColor Cyan

  foreach ($v in $vars) {
      if ($v.isEncrypted -or -not $v.value) {
          Write-Host "SKIP (encrypted or unreadable): $($v.name)" -ForegroundColor Yellow
          continue
      }

      # value from az list is already JSON-encoded; escape quotes for the CLI
      $jsonValue = ($v.value | ConvertTo-Json -Compress) -replace '"', '\"'
      $desc      = if ($v.description) { $v.description } else { "" }

      Write-Host "Copying: $($v.name)  =  $jsonValue" -ForegroundColor Green

      az automation variable create `
          --resource-group $DstRg `
          --automation-account-name $DstAa `
          --name $v.name `
          --value $jsonValue `
          --description $desc `
          --is-encrypted false `
          -o none

      if ($LASTEXITCODE -ne 0) {
          Write-Host "  FAILED: $($v.name)" -ForegroundColor Red
      }
  }

  Write-Host "Done." -ForegroundColor Cyan
