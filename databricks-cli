<#
.SYNOPSIS
    Extracts all runbooks from an Azure Automation Account along with their linked
    schedules (job schedules) and outputs the data in multiple formats for feeding
    to an LLM that will produce Confluence documentation.

.DESCRIPTION
    Uses az-acquired ARM token + Invoke-RestMethod (no 'az rest' / extension dependency).
    Produces three artifacts in ./runbook-inventory/:
      - inventory.json      — full structured data (best for LLM ingestion)
      - inventory.md        — human-readable Markdown table summary
      - inventory.csv       — flat CSV (one row per runbook+schedule pair)
    Also prints a summary table to the console.

.PARAMETER AutomationAccountName
    Override the default Automation Account name.

.EXAMPLE
    .\Get-RunbookInventory.ps1
    .\Get-RunbookInventory.ps1 -AutomationAccountName "s00175prod"

.NOTES
    Requires:
      - Azure CLI installed and logged in (az login)
      - Subscription context set (az account set --subscription "<id>")
#>

[CmdletBinding()]
param(
    [string]$AutomationAccountName = 's00175prod-aa',
    [string]$ResourceGroupName     = 's00175rg-automation'
)

# ---- Configuration -----------------------------------------------------------
$ApiVersion  = '2022-08-08'
$OutputDir   = Join-Path $PSScriptRoot 'runbook-inventory'
# ------------------------------------------------------------------------------

$ErrorActionPreference = 'Stop'
$env:AZURE_CORE_ONLY_SHOW_ERRORS = 'true'

# ---- Acquire token -----------------------------------------------------------

try {
    $tokenJson = & az account get-access-token --resource 'https://management.azure.com/' --output json 2>$null
    if ($LASTEXITCODE -ne 0) { throw 'Token acquisition failed.' }
    $token = ($tokenJson | ConvertFrom-Json).accessToken
}
catch {
    Write-Error "Failed to get ARM token. Run 'az login' first."
    exit 1
}

try {
    $accountJson    = & az account show --output json 2>$null
    $account        = $accountJson | ConvertFrom-Json
    $subscriptionId = $account.id
    Write-Host "Subscription: $($account.name) ($subscriptionId)" -ForegroundColor Cyan
    Write-Host "Automation Account: $AutomationAccountName / RG: $ResourceGroupName`n" -ForegroundColor Cyan
}
catch {
    Write-Error "Failed to read az account context."
    exit 1
}

$Headers = @{ Authorization = "Bearer $token" }
$BaseArm = 'https://management.azure.com'
$AaPath  = "subscriptions/$subscriptionId/resourceGroups/$ResourceGroupName/providers/Microsoft.Automation/automationAccounts/$AutomationAccountName"

# ---- Helper ------------------------------------------------------------------

function Invoke-Arm {
    param([string]$Method, [string]$Url)
    try {
        return Invoke-RestMethod -Method $Method -Uri $Url -Headers $Headers
    }
    catch {
        $msg = $_.Exception.Message
        if ($_.ErrorDetails -and $_.ErrorDetails.Message) { $msg = $_.ErrorDetails.Message }
        throw "ARM call failed [$Method $Url]: $msg"
    }
}

function Format-Schedule {
    param($Schedule)
    if (-not $Schedule) { return $null }
    $p = $Schedule.properties
    [pscustomobject]@{
        Name              = $Schedule.name
        Description       = $p.description
        Frequency         = $p.frequency
        Interval          = $p.interval
        StartTime         = $p.startTime
        ExpiryTime        = if ($p.expiryTime -and $p.expiryTime -ne '9999-12-31T15:59:00-08:00') { $p.expiryTime } else { $null }
        TimeZone          = $p.timeZone
        IsEnabled         = $p.isEnabled
        NextRun           = $p.nextRun
        AdvancedSchedule  = $p.advancedSchedule
    }
}

function Get-FrequencyDescription {
    param($Schedule)
    if (-not $Schedule) { return '(no schedule)' }
    $freq = $Schedule.Frequency
    $intv = $Schedule.Interval
    $desc = switch ($freq) {
        'OneTime' { 'Runs once' }
        'Hour'    { if ($intv -eq 1) { 'Every hour' }   else { "Every $intv hours" } }
        'Day'     { if ($intv -eq 1) { 'Every day' }    else { "Every $intv days" } }
        'Week'    { if ($intv -eq 1) { 'Every week' }   else { "Every $intv weeks" } }
        'Month'   { if ($intv -eq 1) { 'Every month' }  else { "Every $intv months" } }
        default   { "$freq / interval $intv" }
    }
    if (-not $Schedule.IsEnabled) { $desc += ' (DISABLED)' }
    return $desc
}

# ---- Fetch data --------------------------------------------------------------

# Build URLs (api-version embedded; safe in Invoke-RestMethod)
$qs = "?api-version=$ApiVersion"

Write-Host 'Fetching runbooks...' -ForegroundColor Cyan
$runbooks = (Invoke-Arm -Method GET -Url "$BaseArm/$AaPath/runbooks$qs").value
Write-Host "  Found $($runbooks.Count) runbook(s)."

Write-Host 'Fetching schedules...' -ForegroundColor Cyan
$schedules = (Invoke-Arm -Method GET -Url "$BaseArm/$AaPath/schedules$qs").value
Write-Host "  Found $($schedules.Count) schedule(s)."

Write-Host 'Fetching job schedules (links between runbooks and schedules)...' -ForegroundColor Cyan
$jobSchedules = (Invoke-Arm -Method GET -Url "$BaseArm/$AaPath/jobSchedules$qs").value
Write-Host "  Found $($jobSchedules.Count) link(s).`n"

# Index schedules by name
$scheduleByName = @{}
foreach ($s in $schedules) { $scheduleByName[$s.name] = (Format-Schedule -Schedule $s) }

# ---- Build inventory ---------------------------------------------------------

$inventory = [System.Collections.Generic.List[pscustomobject]]::new()

foreach ($rb in $runbooks) {
    # Find all job schedules linked to this runbook
    $linked = $jobSchedules | Where-Object { $_.properties.runbook.name -eq $rb.name }

    $linkedSchedules = @()
    $params          = @{}

    foreach ($js in $linked) {
        $schedName = $js.properties.schedule.name
        $sched     = $scheduleByName[$schedName]
        if ($sched) {
            $linkedSchedules += [pscustomobject]@{
                ScheduleName     = $sched.Name
                Description      = $sched.Description
                Frequency        = $sched.Frequency
                Interval         = $sched.Interval
                StartTime        = $sched.StartTime
                TimeZone         = $sched.TimeZone
                IsEnabled        = $sched.IsEnabled
                NextRun          = $sched.NextRun
                Summary          = (Get-FrequencyDescription -Schedule $sched)
                AdvancedSchedule = $sched.AdvancedSchedule
                JobScheduleId    = $js.properties.jobScheduleId
                Parameters       = $js.properties.parameters
                RunOn            = $js.properties.runOn
            }
        }
    }

    $entry = [pscustomobject]@{
        RunbookName   = $rb.name
        RunbookType   = $rb.properties.runbookType
        State         = $rb.properties.state
        Description   = $rb.properties.description
        LogVerbose    = $rb.properties.logVerbose
        LogProgress   = $rb.properties.logProgress
        CreationTime  = $rb.properties.creationTime
        LastModified  = $rb.properties.lastModifiedTime
        Tags          = $rb.tags
        Schedules     = $linkedSchedules
        ScheduleCount = $linkedSchedules.Count
    }

    $inventory.Add($entry)
}

# ---- Output: ensure directory ------------------------------------------------

if (-not (Test-Path $OutputDir)) {
    New-Item -ItemType Directory -Path $OutputDir -Force | Out-Null
}

# ---- Output: JSON (best for LLM) ---------------------------------------------

$jsonPath = Join-Path $OutputDir 'inventory.json'
$inventory | ConvertTo-Json -Depth 10 | Out-File -FilePath $jsonPath -Encoding utf8

# ---- Output: Markdown --------------------------------------------------------

$mdPath = Join-Path $OutputDir 'inventory.md'
$md     = [System.Collections.Generic.List[string]]::new()

$md.Add("# Automation Account Inventory")
$md.Add("")
$md.Add("**Account:** ``$AutomationAccountName``  ")
$md.Add("**Resource Group:** ``$ResourceGroupName``  ")
$md.Add("**Subscription:** ``$($account.name)``  ")
$md.Add("**Generated:** $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss zzz')")
$md.Add("")
$md.Add("## Summary")
$md.Add("")
$md.Add("- Total runbooks: **$($runbooks.Count)**")
$md.Add("- Total schedules: **$($schedules.Count)**")
$md.Add("- Total runbook-schedule links: **$($jobSchedules.Count)**")
$md.Add("- Runbooks with at least one schedule: **$(($inventory | Where-Object ScheduleCount -gt 0).Count)**")
$md.Add("- Runbooks with no schedule: **$(($inventory | Where-Object ScheduleCount -eq 0).Count)**")
$md.Add("")
$md.Add("## Runbooks")
$md.Add("")
$md.Add("| Runbook | Type | State | Schedules | Description |")
$md.Add("|---------|------|-------|-----------|-------------|")

foreach ($e in ($inventory | Sort-Object RunbookName)) {
    $schedSummary = if ($e.Schedules.Count -gt 0) {
        ($e.Schedules | ForEach-Object { "$($_.ScheduleName) ($($_.Summary))" }) -join '; '
    } else {
        '_none_'
    }
    $desc = if ($e.Description) { ($e.Description -replace '\|','\\|' -replace '\r?\n',' ') } else { '' }
    $md.Add("| ``$($e.RunbookName)`` | $($e.RunbookType) | $($e.State) | $schedSummary | $desc |")
}

$md.Add("")
$md.Add("## Schedules Detail")
$md.Add("")

foreach ($e in ($inventory | Where-Object ScheduleCount -gt 0 | Sort-Object RunbookName)) {
    $md.Add("### ``$($e.RunbookName)``")
    $md.Add("")
    foreach ($s in $e.Schedules) {
        $md.Add("- **$($s.ScheduleName)** — $($s.Summary)")
        if ($s.StartTime) { $md.Add("  - Start: $($s.StartTime) ($($s.TimeZone))") }
        if ($s.NextRun)   { $md.Add("  - Next run: $($s.NextRun)") }
        if ($s.Description) { $md.Add("  - Description: $($s.Description)") }
        if ($s.Parameters -and $s.Parameters.PSObject.Properties.Count -gt 0) {
            $paramStr = ($s.Parameters.PSObject.Properties | ForEach-Object { "$($_.Name)=$($_.Value)" }) -join ', '
            $md.Add("  - Parameters: $paramStr")
        }
        if ($s.RunOn) { $md.Add("  - Hybrid Worker Group: $($s.RunOn)") }
    }
    $md.Add("")
}

$md -join "`r`n" | Out-File -FilePath $mdPath -Encoding utf8

# ---- Output: CSV (one row per runbook+schedule combo) -----------------------

$csvPath = Join-Path $OutputDir 'inventory.csv'
$rows    = [System.Collections.Generic.List[pscustomobject]]::new()

foreach ($e in $inventory) {
    if ($e.Schedules.Count -eq 0) {
        $rows.Add([pscustomobject]@{
            RunbookName    = $e.RunbookName
            RunbookType    = $e.RunbookType
            RunbookState   = $e.State
            ScheduleName   = ''
            ScheduleSummary= ''
            Frequency      = ''
            Interval       = ''
            StartTime      = ''
            TimeZone       = ''
            IsEnabled      = ''
            NextRun        = ''
            Description    = $e.Description
        })
    } else {
        foreach ($s in $e.Schedules) {
            $rows.Add([pscustomobject]@{
                RunbookName    = $e.RunbookName
                RunbookType    = $e.RunbookType
                RunbookState   = $e.State
                ScheduleName   = $s.ScheduleName
                ScheduleSummary= $s.Summary
                Frequency      = $s.Frequency
                Interval       = $s.Interval
                StartTime      = $s.StartTime
                TimeZone       = $s.TimeZone
                IsEnabled      = $s.IsEnabled
                NextRun        = $s.NextRun
                Description    = $e.Description
            })
        }
    }
}

$rows | Export-Csv -Path $csvPath -NoTypeInformation -Encoding utf8

# ---- Console summary ---------------------------------------------------------

Write-Host '=== Summary ===' -ForegroundColor Cyan
$inventory |
    Sort-Object RunbookName |
    Select-Object RunbookName, RunbookType, State, ScheduleCount,
        @{ N = 'Schedules'; E = { ($_.Schedules.ScheduleName -join ', ') } } |
    Format-Table -AutoSize

Write-Host ''
Write-Host 'Output files:' -ForegroundColor Green
Write-Host "  JSON  (LLM-friendly):  $jsonPath"
Write-Host "  Markdown (readable):    $mdPath"
Write-Host "  CSV (spreadsheet):      $csvPath"
Write-Host ''
Write-Host 'Tip: paste inventory.json or inventory.md into your LLM prompt and ask it to produce a Confluence page.' -ForegroundColor DarkCyan
