  <#
    Copies Automation Account variables across subscriptions.
    Source:      s00175autovm  (sub 535d8f2e-f08c-4475-8608-3b8136d13cbd)
    Destination: s00175prod    (sub f3bee883-599d-42ef-aeb7-d5fe4abeb4ea)
  #>

  param([switch]$WhatIf)

  $ErrorActionPreference = "Stop"

  $SrcSub = "535d8f2e-f08c-4475-8608-3b8136d13cbd"
  $SrcRg  = "s00175rgsfd02-1"
  $SrcAa  = "s00175autovm"

  $DstSub = "f3bee883-599d-42ef-aeb7-d5fe4abeb4ea"
  $DstRg  = "s00175rg-automation"
  $DstAa  = "s00175prod"

  $ApiVersion = "2023-11-01"

  $srcBase = "https://management.azure.com/subscriptions/$SrcSub/resourceGroups/$SrcRg/providers/Microsoft.Automation/automationAccounts/$SrcAa/variables"
  $dstBase = "https://management.azure.com/subscriptions/$DstSub/resourceGroups/$DstRg/providers/Microsoft.Automation/automationAccounts/$DstAa/variables"

  Write-Host "Fetching variables from $SrcAa..." -ForegroundColor Cyan
  $listJson = az rest --method get --url "${srcBase}?api-version=$ApiVersion"
  if ($LASTEXITCODE -ne 0) { throw "Failed to list source variables." }
  $list = $listJson | ConvertFrom-Json
  Write-Host "Found $($list.value.Count) variables." -ForegroundColor Cyan

  $copied = 0; $skipped = 0; $failed = 0

  foreach ($v in $list.value) {
      $name  = $v.name
      $props = $v.properties

      if ($props.isEncrypted -or -not $props.value) {
          Write-Host "SKIP (encrypted or unreadable): $name" -ForegroundColor Yellow
          $skipped++
          continue
      }

      $body = @{
          name       = $name
          properties = @{
              value       = $props.value
              description = [string]$props.description
              isEncrypted = $false
          }
      } | ConvertTo-Json -Depth 5 -Compress

      if ($WhatIf) {
          Write-Host "WhatIf: would create $name = $($props.value)" -ForegroundColor Magenta
          continue
      }

      $tmp = New-TemporaryFile
      try {
          Set-Content -Path $tmp.FullName -Value $body -Encoding utf8
          az rest --method put `
              --url  "$dstBase/$name`?api-version=$ApiVersion" `
              --body "@$($tmp.FullName)" `
              --headers "Content-Type=application/json" `
              -o none

          if ($LASTEXITCODE -eq 0) {
              Write-Host "Copied: $name" -ForegroundColor Green
              $copied++
          } else {
              Write-Host "FAILED: $name" -ForegroundColor Red
              $failed++
          }
      } finally {
          Remove-Item $tmp.FullName -ErrorAction SilentlyContinue
      }
  }

  Write-Host ""
  Write-Host "Summary: copied=$copied  skipped=$skipped  failed=$failed" -ForegroundColor Cyan
