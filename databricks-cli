import requests

tenant_id = dbutils.secrets.get("scope-name", "tenant-id")
client_id = dbutils.secrets.get("scope-name", "client-id")
client_secret = dbutils.secrets.get("scope-name", "client-secret")
storage_account = "yourstorageaccount"
container = "my-new-container"

# Step 1: get token
token_resp = requests.post(
    f"https://login.microsoftonline.com/{tenant_id}/oauth2/v2.0/token",
    data={
        "grant_type": "client_credentials",
        "client_id": client_id,
        "client_secret": client_secret,
        "scope": "https://storage.azure.com/.default",
    },
)
token_resp.raise_for_status()
token = token_resp.json()["access_token"]

# Step 2: create container (Blob endpoint)
from email.utils import formatdate
create_resp = requests.put(
    f"https://{storage_account}.blob.core.windows.net/{container}?restype=container",
    headers={
        "Authorization": f"Bearer {token}",
        "x-ms-version": "2021-12-02",
        "x-ms-date": formatdate(usegmt=True),
        "Content-Length": "0",
    },
)
print(create_resp.status_code, create_resp.text)
# 201 = created, 409 = already exists
