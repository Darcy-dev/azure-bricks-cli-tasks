  $DstSub = "f3bee883-599d-42ef-aeb7-d5fe4abeb4ea"
  $DstRg  = "s00175rg-automation"
  $DstAa  = "s00175prod"
  $Api    = "2023-11-01"

  # Names of encrypted variables to migrate
  $EncryptedNames = @(
      "apiSecret",
      "connectionString",
      "anotherSecret"
  )

  Connect-AzAccount -Identity | Out-Null
  $token = (Get-AzAccessToken -ResourceUrl "https://management.azure.com/").Token
  $headers = @{ Authorization = "Bearer $token"; "Content-Type" = "application/json" }

  foreach ($n in $EncryptedNames) {
      $plain = Get-AutomationVariable -Name $n
      if ($null -eq $plain) { Write-Warning "Not found: $n"; continue }

      $body = @{
          name       = $n
          properties = @{
              value       = ($plain | ConvertTo-Json -Compress)  # JSON-encode
              isEncrypted = $true
              description = "Migrated from source AA"
          }
      } | ConvertTo-Json -Depth 5 -Compress

      $url = "https://management.azure.com/subscriptions/$DstSub/resourceGroups/$DstRg/providers/Microsoft.Automation/automationAccounts/$DstAa/variables/$n`?api-version=$Api"

      try {
          Invoke-RestMethod -Method Put -Uri $url -Headers $headers -Body $body | Out-Null
          Write-Output "Migrated: $n"
      } catch {
          Write-Error "Failed $n : $_"
      }
  }
