<#
.SYNOPSIS
    Generates Terraform import blocks for all resources inside an Azure Automation Account.

.DESCRIPTION
    Inspects the AA via ARM REST and emits a single 'imports.tf' file containing 
    'import' blocks (Terraform 1.5+ syntax). Use 'terraform plan -generate-config-out=generated.tf'
    afterward to materialize the resource configurations.

.EXAMPLE
    .\Generate-TerraformImports.ps1
#>

[CmdletBinding()]
param(
    [string]$AutomationAccountName = 's00175prod',
    [string]$ResourceGroupName     = 's00175rg-automation',
    [string]$OutputFile            = (Join-Path $PSScriptRoot 'imports.tf')
)

$ApiVersion = '2022-08-08'
$ErrorActionPreference = 'Stop'
$env:AZURE_CORE_ONLY_SHOW_ERRORS = 'true'

# Get token + subscription
$token   = (& az account get-access-token --resource 'https://management.azure.com/' --output json | ConvertFrom-Json).accessToken
$account = (& az account show --output json | ConvertFrom-Json)
$subId   = $account.id

$Headers = @{ Authorization = "Bearer $token" }
$BaseArm = 'https://management.azure.com'
$AaPath  = "subscriptions/$subId/resourceGroups/$ResourceGroupName/providers/Microsoft.Automation/automationAccounts/$AutomationAccountName"

function Get-Items($subResource) {
    try {
        return (Invoke-RestMethod -Method GET -Headers $Headers -Uri "$BaseArm/$AaPath/$subResource`?api-version=$ApiVersion").value
    }
    catch {
        Write-Warning "Failed fetching $subResource : $($_.Exception.Message)"
        return @()
    }
}

# Sanitize names for use as Terraform resource labels (must be valid identifiers)
function ConvertTo-TfLabel($name) {
    $clean = $name -replace '[^a-zA-Z0-9_]', '_'
    if ($clean -match '^\d') { $clean = "_$clean" }
    return $clean.ToLower()
}

$out = [System.Collections.Generic.List[string]]::new()
$out.Add('# Generated Terraform import blocks. Run: terraform plan -generate-config-out=generated.tf')
$out.Add("# Source: $AutomationAccountName ($ResourceGroupName)")
$out.Add('')

# Automation Account itself
$out.Add('import {')
$out.Add("  to = azurerm_automation_account.$(ConvertTo-TfLabel $AutomationAccountName)")
$out.Add("  id = `"/subscriptions/$subId/resourceGroups/$ResourceGroupName/providers/Microsoft.Automation/automationAccounts/$AutomationAccountName`"")
$out.Add('}')
$out.Add('')

$resourceMap = [ordered]@{
    'runbooks'                   = 'azurerm_automation_runbook'
    'schedules'                  = 'azurerm_automation_schedule'
    'jobSchedules'               = 'azurerm_automation_job_schedule'
    'variables'                  = 'azurerm_automation_variable_string'
    'credentials'                = 'azurerm_automation_credential'
    'connections'                = 'azurerm_automation_connection'
    'certificates'               = 'azurerm_automation_certificate'
    'modules'                    = 'azurerm_automation_module'
    'webhooks'                   = 'azurerm_automation_webhook'
    'hybridRunbookWorkerGroups'  = 'azurerm_automation_hybrid_runbook_worker_group'
}

foreach ($subResource in $resourceMap.Keys) {
    $tfType = $resourceMap[$subResource]
    Write-Host "Fetching $subResource..." -ForegroundColor Cyan
    $items = Get-Items $subResource

    if (-not $items -or $items.Count -eq 0) {
        $out.Add("# (no $subResource found)")
        $out.Add('')
        continue
    }

    $out.Add("# === $subResource ($($items.Count)) ===")
    foreach ($item in $items) {
        $name  = $item.name
        $label = ConvertTo-TfLabel $name
        $id    = "/subscriptions/$subId/resourceGroups/$ResourceGroupName/providers/Microsoft.Automation/automationAccounts/$AutomationAccountName/$subResource/$name"

        $out.Add('import {')
        $out.Add("  to = $tfType.$label")
        $out.Add("  id = `"$id`"")
        $out.Add('}')
    }
    $out.Add('')
}

$out -join "`r`n" | Out-File -FilePath $OutputFile -Encoding utf8
Write-Host "Wrote $OutputFile" -ForegroundColor Green
Write-Host ''
Write-Host 'Next steps:' -ForegroundColor Yellow
Write-Host '  1. terraform init'
Write-Host '  2. terraform plan -generate-config-out=generated.tf'
Write-Host '  3. terraform apply  (this completes the import without changes)'
Write-Host '  4. Review and clean up generated.tf, then commit.'
