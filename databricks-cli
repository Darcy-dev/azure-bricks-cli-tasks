<#
.SYNOPSIS
    Copies all runbooks from one Azure Automation Account to another using Azure CLI (az).

.DESCRIPTION
    Uses 'az automation' commands to export and re-import runbooks. Works on Windows with
    just Azure CLI installed — no PowerShell Az module required.

.PARAMETER Overwrite
    If specified, existing runbooks in the destination will be deleted and recreated.

.EXAMPLE
    .\Copy-Runbooks-AzCli.ps1
    .\Copy-Runbooks-AzCli.ps1 -Overwrite

.NOTES
    Requires:
      - Azure CLI installed (az --version)
      - automation extension: az extension add --name automation
      - Logged in: az login
#>

[CmdletBinding()]
param(
    [switch]$Overwrite
)

# ---- Configuration -----------------------------------------------------------
$ResourceGroupName    = 's00175rg-automation'
$SourceAutomationName = 's00175prod-aa'
$DestAutomationName   = 's00175prod'
$ExportPath           = Join-Path $PSScriptRoot 'runbook-export'
# ------------------------------------------------------------------------------

$ErrorActionPreference = 'Stop'

# Helper: run az and return parsed JSON, or fail with the raw output
function Invoke-Az {
    param([Parameter(ValueFromRemainingArguments = $true)][string[]]$Args)
    $output = & az @Args 2>&1
    if ($LASTEXITCODE -ne 0) {
        throw "az $($Args -join ' ') failed:`n$output"
    }
    return $output
}

function Invoke-AzJson {
    param([Parameter(ValueFromRemainingArguments = $true)][string[]]$Args)
    $raw = Invoke-Az @Args
    if (-not $raw) { return $null }
    return ($raw | ConvertFrom-Json)
}

# 1. Verify az is installed and logged in
try {
    $null = & az --version 2>&1
    if ($LASTEXITCODE -ne 0) { throw 'az CLI not found in PATH.' }
}
catch {
    Write-Error "Azure CLI not installed. Get it from https://aka.ms/installazurecli"
    exit 1
}

try {
    $account = Invoke-AzJson account show
    Write-Host "Logged in as: $($account.user.name) | Subscription: $($account.name)" -ForegroundColor Cyan
}
catch {
    Write-Error "Not logged in. Run: az login"
    exit 1
}

# 2. Ensure automation extension is installed
$ext = Invoke-AzJson extension list
if (-not ($ext | Where-Object name -eq 'automation')) {
    Write-Host "Installing 'automation' extension..." -ForegroundColor Cyan
    Invoke-Az extension add --name automation | Out-Null
}

# 3. Validate both Automation Accounts exist
Write-Host "`nValidating Automation Accounts..." -ForegroundColor Cyan
try {
    $srcAA  = Invoke-AzJson automation account show -g $ResourceGroupName --automation-account-name $SourceAutomationName
    $destAA = Invoke-AzJson automation account show -g $ResourceGroupName --automation-account-name $DestAutomationName
    Write-Host "  [OK] Source:      $($srcAA.name) ($($srcAA.location))"
    Write-Host "  [OK] Destination: $($destAA.name) ($($destAA.location))"
}
catch {
    Write-Error "Failed to access Automation Accounts: $_"
    exit 1
}

# 4. Prep export directory
if (Test-Path $ExportPath) { Remove-Item $ExportPath -Recurse -Force }
New-Item -ItemType Directory -Path $ExportPath -Force | Out-Null

# 5. List source runbooks
Write-Host "`nFetching runbooks from '$SourceAutomationName'..." -ForegroundColor Cyan
$runbooks = Invoke-AzJson automation runbook list `
    -g $ResourceGroupName `
    --automation-account-name $SourceAutomationName

if (-not $runbooks) {
    Write-Warning 'No runbooks found in source. Nothing to copy.'
    exit 0
}
Write-Host "Found $($runbooks.Count) runbook(s).`n" -ForegroundColor Cyan

# 6. List destination runbooks for existence check
$destRunbooks = Invoke-AzJson automation runbook list `
    -g $ResourceGroupName `
    --automation-account-name $DestAutomationName
$destNames = @($destRunbooks | Select-Object -ExpandProperty name)

# 7. Copy loop
$results = [System.Collections.Generic.List[pscustomobject]]::new()

foreach ($rb in $runbooks) {
    $name = $rb.name
    $type = $rb.runbookType
    Write-Host "[$name] type=$type" -ForegroundColor Yellow

    if ($destNames -contains $name -and -not $Overwrite) {
        Write-Host '  -> SKIP (already exists; use -Overwrite to replace)' -ForegroundColor DarkYellow
        $results.Add([pscustomobject]@{ Name = $name; Type = $type; Status = 'Skipped' })
        continue
    }

    # Map runbook type to file extension
    $extension = switch ($type) {
        'PowerShell'              { 'ps1' }
        'PowerShell72'            { 'ps1' }
        'PowerShellWorkflow'      { 'ps1' }
        'Python2'                 { 'py' }
        'Python3'                 { 'py' }
        'GraphPowerShell'         { 'graphrunbook' }
        'GraphPowerShellWorkflow' { 'graphrunbook' }
        default                   { 'txt' }
    }
    $contentFile = Join-Path $ExportPath "$name.$extension"

    try {
        # 7a. Export content from source (writes to file)
        Write-Host '  -> Exporting from source...'
        $content = Invoke-Az automation runbook show-content `
            -g $ResourceGroupName `
            --automation-account-name $SourceAutomationName `
            --name $name
        $content | Out-File -FilePath $contentFile -Encoding utf8

        # 7b. Delete existing destination runbook if overwriting
        if ($destNames -contains $name -and $Overwrite) {
            Write-Host '  -> Removing existing destination runbook...'
            Invoke-Az automation runbook delete `
                -g $ResourceGroupName `
                --automation-account-name $DestAutomationName `
                --name $name --yes | Out-Null
        }

        # 7c. Create the runbook shell in destination
        Write-Host '  -> Creating in destination...'
        $description = if ($rb.description) { $rb.description } else { '' }
        Invoke-Az automation runbook create `
            -g $ResourceGroupName `
            --automation-account-name $DestAutomationName `
            --name $name `
            --type $type `
            --location $destAA.location `
            --description $description | Out-Null

        # 7d. Upload content to draft
        Write-Host '  -> Uploading content...'
        Invoke-Az automation runbook replace-content `
            -g $ResourceGroupName `
            --automation-account-name $DestAutomationName `
            --name $name `
            --content "@$contentFile" | Out-Null

        # 7e. Publish
        Write-Host '  -> Publishing...'
        Invoke-Az automation runbook publish `
            -g $ResourceGroupName `
            --automation-account-name $DestAutomationName `
            --name $name | Out-Null

        Write-Host '  -> DONE' -ForegroundColor Green
        $results.Add([pscustomobject]@{ Name = $name; Type = $type; Status = 'Copied' })
    }
    catch {
        Write-Host "  -> FAILED: $_" -ForegroundColor Red
        $results.Add([pscustomobject]@{ Name = $name; Type = $type; Status = "Failed: $($_.Exception.Message)" })
    }
}

# 8. Summary
Write-Host "`n=== Summary ===" -ForegroundColor Cyan
$results | Format-Table -AutoSize

$copied  = ($results | Where-Object Status -eq 'Copied').Count
$skipped = ($results | Where-Object Status -eq 'Skipped').Count
$failed  = ($results | Where-Object { $_.Status -like 'Failed*' }).Count

Write-Host "Copied:  $copied"  -ForegroundColor Green
Write-Host "Skipped: $skipped" -ForegroundColor DarkYellow
Write-Host "Failed:  $failed"  -ForegroundColor $(if ($failed) { 'Red' } else { 'Gray' })
Write-Host "`nExported runbook files preserved in: $ExportPath"

if ($failed -gt 0) { exit 1 }
