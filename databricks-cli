  $SrcRg = "s00175rgsfd02-1"
  $SrcAa = "s00175autovm"
  $DstRg = "s00175rg-automation"
  $DstAa = "s00175prod"
  $SubId = (az account show --query id -o tsv)

  $apiVer = "2022-08-08"
  $srcBase = "https://management.azure.com/subscriptions/$SubId/resourceGroups/$SrcRg/providers/Microsoft.Automation/automationAccounts/$SrcAa/variables"
  $dstBase = "https://management.azure.com/subscriptions/$SubId/resourceGroups/$DstRg/providers/Microsoft.Automation/automationAccounts/$DstAa/variables"

  $list = az rest --method get --url "${srcBase}?api-version=$apiVer" | ConvertFrom-Json

  foreach ($v in $list.value) {
      $name = $v.name
      $props = $v.properties
      if ($props.isEncrypted -or -not $props.value) {
          Write-Host "SKIP (encrypted): $name" -ForegroundColor Yellow
          continue
      }

      $body = @{
          name = $name
          properties = @{
              value       = $props.value          
              description = $props.description
              isEncrypted = $false
          }
      } | ConvertTo-Json -Depth 5 -Compress

      Write-Host "Copying: $name" -ForegroundColor Green
      az rest --method put `
          --url "$dstBase/$name`?api-version=$apiVer" `
          --body $body `
          --headers "Content-Type=application/json" | Out-Null
  }
